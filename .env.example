# Environment mode: use "dev" for local development and "prod" for hardened production checks
OA_ENV=dev

# Database credentials (REQUIRED for non-dev mode; must be changed from defaults)
DB_NAME=openanalytics
DB_USER=openanalytics
DB_PASSWORD=changeme

# Redis password (REQUIRED)
REDIS_PASSWORD=changeme-redis

# API auth secret (REQUIRED)
JWT_SECRET=generate-a-random-secret-here

# Host ports (API/dashboard are exposed by default)
# DASHBOARD_PORT=3100
# API_PORT=3101

# Local dev only: Postgres/Redis host ports are published via docker-compose.dev.yml
# DB_PORT=5433
# REDIS_PORT=6380

# Public tunnel URL (set this if you expose the API via Cloudflare Tunnel / ngrok)
# TRACKER_URL=https://analytics.yourdomain.com

# CORS origin - set to your production domain when using a tunnel
# Always keep http://localhost:3100 so the dashboard can reach the API
# CORS_ORIGIN=http://localhost:3100,https://yourdomain.com

# Set to false to disable new user registration
# REGISTRATION_ENABLED=true

# AI Setup Assistant - set to enable AI-powered analytics suggestions
# ANTHROPIC_API_KEY=sk-ant-...
