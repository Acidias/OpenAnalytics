{
  "name": "@openanalytics/tracker",
  "version": "0.1.0",
  "description": "Lightweight privacy-first analytics tracker script",
  "main": "dist/oa.js",
  "scripts": {
    "build": "node esbuild.config.js",
    "build:check": "node -e \"const fs=require('fs');const z=require('zlib');const b=fs.readFileSync('dist/oa.js');console.log('Raw:',b.length,'bytes');console.log('Gzipped:',z.gzipSync(b).length,'bytes')\""
  },
  "devDependencies": {
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "license": "MIT"
}
